                "type": "p",
                "children": [{ "text": "" }]
              },
              {
                "type": "p",
                "children": [
                  { "text": "4. KI-Webdesign & Marketing", "bold": true }
                ]
              },
              {
                "type": "p",
                "children": [
                  { "text": "SEO/SEA-Cluster, Landing Pages, Content-Automatisierung, A/B-Testing und Chatbot-gestuetzte Lead-Qualifizierung. Ab 150 EUR/Monat." }
                ]
              }
            ]
