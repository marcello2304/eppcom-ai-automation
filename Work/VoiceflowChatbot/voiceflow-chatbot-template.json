              {
                "type": "p",
                "children": [
                  { "text": "24/7 verfuegbar auf Web, WhatsApp, Telegram und Sprache. Lead-Qualifizierung und CRM-Integration. Ab 133 EUR/Monat." }
                ]
              },
              {
                "type": "p",
                "children": [{ "text": "" }]
              },
              {
                "type": "p",
                "children": [
                  { "text": "3. KI-Strategie & Schulungen", "bold": true }
                ]
